{
  "name": "agent-ready",
  "version": "0.0.0",
  "description": "Scan sites for agent readiness and scaffold framework-specific machine-readable endpoints.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "bin": {
    "agent-ready": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "packageManager": "npm@11.3.0",
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "prepublishOnly": "npm run check && npm run test && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit"
  },
  "keywords": [
    "agents",
    "cli",
    "cloudflare",
    "llms",
    "mcp",
    "scaffold",
    "webmcp"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
